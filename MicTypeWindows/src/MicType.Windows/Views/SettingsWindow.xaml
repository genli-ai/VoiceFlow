<Window x:Class="MicType.Win.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MicType Settings"
        Width="680"
        Height="620"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <TabControl>
            <TabItem x:Name="GeneralTab" Header="General">
                <StackPanel Margin="16" Orientation="Vertical">
                    <TextBlock x:Name="LanguageLabel" Text="Language" FontWeight="SemiBold" />
                    <ComboBox x:Name="LanguageBox" Width="220" HorizontalAlignment="Left" Margin="0,6,0,14" SelectionChanged="OnLanguageChanged">
                        <ComboBoxItem Tag="Zh" Content="中文" />
                        <ComboBoxItem Tag="En" Content="English" />
                    </ComboBox>
                    <TextBlock x:Name="HotkeyLabel" Text="Dictation hotkey" FontWeight="SemiBold" />
                    <ComboBox x:Name="HotkeyBox" Width="220" HorizontalAlignment="Left" Margin="0,6,0,14">
                        <ComboBoxItem Tag="RightControl" Content="Right Ctrl" />
                        <ComboBoxItem Tag="RightShift" Content="Right Shift" />
                    </ComboBox>
                    <CheckBox x:Name="PlaySoundsBox" Margin="0,0,0,8" Content="Play sounds" />
                    <CheckBox x:Name="RestoreClipboardBox" Margin="0,0,0,8" Content="Restore clipboard after paste" />
                    <TextBlock x:Name="GestureHelp" TextWrapping="Wrap" Foreground="#666" Margin="0,8,0,0" />
                </StackPanel>
            </TabItem>
            <TabItem x:Name="RecognitionTab" Header="Recognition">
                <StackPanel Margin="16">
                    <TextBlock x:Name="AsrStatusLabel" FontWeight="SemiBold" />
                    <TextBlock x:Name="AsrStatusText" TextWrapping="Wrap" Foreground="#A16207" Margin="0,6,0,8" />
                    <TextBlock x:Name="ModelDirectoryText" TextWrapping="Wrap" Foreground="#666" Margin="0,0,0,10" />
                    <ProgressBar x:Name="ModelDownloadProgress"
                                 Height="12"
                                 Minimum="0"
                                 Maximum="100"
                                 Visibility="Collapsed"
                                 Margin="0,0,0,10" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Button x:Name="DownloadModelButton" Width="130" Margin="0,0,8,0" Click="OnDownloadModel" />
                        <Button x:Name="RedownloadModelButton" Width="130" Margin="0,0,8,0" Click="OnRedownloadModel" />
                        <Button x:Name="CancelModelDownloadButton" Width="100" Click="OnCancelModelDownload" Visibility="Collapsed" />
                    </StackPanel>
                    <TextBlock x:Name="VocabularyLabel" FontWeight="SemiBold" />
                    <TextBox x:Name="VocabularyBox" AcceptsReturn="True" TextWrapping="Wrap" Height="130" Margin="0,6,0,8" />
                    <TextBlock x:Name="VocabularyHelp" TextWrapping="Wrap" Foreground="#666" />
                </StackPanel>
            </TabItem>
            <TabItem x:Name="AiTab" Header="AI Polish">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16">
                        <TextBlock x:Name="PolishModeLabel" FontWeight="SemiBold" />
                        <ComboBox x:Name="PolishLevelBox" Width="260" HorizontalAlignment="Left" Margin="0,6,0,14">
                            <ComboBoxItem Tag="Off" Content="Transcribe only" />
                            <ComboBoxItem Tag="Smart" Content="AI polish" />
                        </ComboBox>
                        <TextBlock x:Name="ProviderLabel" FontWeight="SemiBold" />
                        <ComboBox x:Name="ProviderBox" Width="220" HorizontalAlignment="Left" Margin="0,6,0,14" SelectionChanged="OnProviderChanged">
                            <ComboBoxItem Tag="OpenAi" Content="OpenAI (GPT)" />
                            <ComboBoxItem Tag="DeepSeek" Content="DeepSeek" />
                        </ComboBox>
                        <TextBlock Text="Base URL" FontWeight="SemiBold" />
                        <TextBox x:Name="BaseUrlBox" Margin="0,6,0,12" />
                        <TextBlock x:Name="PolishModelLabel" FontWeight="SemiBold" />
                        <TextBox x:Name="PolishModelBox" Margin="0,6,0,12" />
                        <TextBlock x:Name="CommandModelLabel" FontWeight="SemiBold" />
                        <TextBox x:Name="CommandModelBox" Margin="0,6,0,12" />
                        <TextBlock Text="API Key" FontWeight="SemiBold" />
                        <PasswordBox x:Name="ApiKeyBox" Margin="0,6,0,8" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Button x:Name="SaveKeyButton" Width="110" Margin="0,0,8,0" Click="OnSaveKey" />
                            <Button x:Name="TestPolishButton" Width="130" Margin="0,0,8,0" Click="OnTestPolishModel" />
                            <Button x:Name="TestCommandButton" Width="130" Click="OnTestCommandModel" />
                        </StackPanel>
                        <TextBlock x:Name="TestResultText" TextWrapping="Wrap" Foreground="#666" Margin="0,0,0,14" />
                        <TextBlock x:Name="TemperatureLabel" FontWeight="SemiBold" />
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,8">
                            <TextBlock x:Name="PolishTempLabel" Width="140" />
                            <Slider x:Name="PolishTempSlider" Width="280" Minimum="0" Maximum="1.5" TickFrequency="0.1" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <TextBlock x:Name="CommandTempLabel" Width="140" />
                            <Slider x:Name="CommandTempSlider" Width="280" Minimum="0" Maximum="1.5" TickFrequency="0.1" />
                        </StackPanel>
                        <TextBlock x:Name="AboutMeLabel" FontWeight="SemiBold" />
                        <TextBox x:Name="AboutMeBox" AcceptsReturn="True" TextWrapping="Wrap" Height="70" Margin="0,6,0,12" />
                        <TextBlock x:Name="RulesLabel" FontWeight="SemiBold" />
                        <TextBox x:Name="RulesBox" AcceptsReturn="True" TextWrapping="Wrap" Height="90" Margin="0,6,0,12" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem x:Name="AboutTab" Header="About">
                <StackPanel Margin="16">
                    <TextBlock Text="MicType for Windows" FontSize="24" FontWeight="Bold" />
                    <TextBlock x:Name="AboutText" TextWrapping="Wrap" Margin="0,12,0,0" />
                </StackPanel>
            </TabItem>
        </TabControl>
        <Button x:Name="SaveButton"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Width="120"
                Height="34"
                Click="OnSaveSettings" />
    </Grid>
</Window>
