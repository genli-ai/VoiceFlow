<Window x:Class="MicType.Win.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="520"
        Height="96"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStyle="None"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        IsHitTestVisible="False">
    <Border x:Name="Shell"
            Background="#DD111111"
            CornerRadius="24"
            Padding="18,12"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <Ellipse x:Name="Dot" Width="10" Height="10" Fill="#F87171" Margin="0,0,10,0" />
            <ProgressBar x:Name="Spinner" Width="34" Height="8" IsIndeterminate="True" Visibility="Collapsed" Margin="0,0,10,0" />
            <TextBlock x:Name="MessageText"
                       Text="Listening..."
                       Foreground="White"
                       FontSize="13"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       MaxWidth="420" />
        </StackPanel>
    </Border>
</Window>
